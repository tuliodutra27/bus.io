# Copie este arquivo para .env na raiz do projeto e preencha TODOS os valores.
# O .env fica na mesma pasta do docker-compose.yml e NÃO deve ser commitado.

# --- Banco de dados ---
MYSQL_ROOT_PASSWORD=troque_a_senha_root
MYSQL_DATABASE=busio
MYSQL_USER=busio
MYSQL_PASSWORD=troque_a_senha_busio

# Popula o banco com dados de exemplo na primeira subida
SEED_ON_START=true

# --- Active Directory (LDAP) ---
LDAP_SERVER=ldap://dc.aliseo.local
LDAP_DOMAIN=aliseo.local
LDAP_BASE_DN=DC=aliseo,DC=local

# Grupos de acesso (CN do grupo no AD)
LDAP_GROUP_ADMIN=GRP_App_Bus.io_Admin
LDAP_GROUP_LOGISTICA=GRP_App_Bus.io_Logistica
LDAP_GROUP_VIEWER=GRP_App_Bus.io_Viewer

# --- Sessão ---
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=gere_um_valor_aleatorio_longo_aqui
