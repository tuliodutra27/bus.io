# Copie este arquivo para .env na raiz do projeto e ajuste os valores.
# O .env fica na mesma pasta do docker-compose.yml.

# --- Banco de dados ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=busio
MYSQL_USER=busio
MYSQL_PASSWORD=busio

# Popula o banco com dados de exemplo na primeira subida
SEED_ON_START=true

# --- Active Directory (LDAP) ---
# Endereço do Domain Controller (ldap:// ou ldaps://)
LDAP_SERVER=ldap://dc.aliseo.local

# Domínio usado no login UPN: usuario@LDAP_DOMAIN
LDAP_DOMAIN=aliseo.local

# Base DN de busca (geralmente a raiz do seu domínio)
LDAP_BASE_DN=DC=aliseo,DC=local

# Nome (CN) do grupo AD que libera acesso ao app
LDAP_GROUP=GRP_App_Acessar_Bus.io

# --- Sessão ---
# Troque por uma string longa e aleatória em produção.
# Exemplo: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=troque-por-valor-aleatorio-longo
