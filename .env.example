# Copie para .env e ajuste se quiser. Os valores padrão já funcionam com o docker-compose.
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=busio
MYSQL_USER=busio
MYSQL_PASSWORD=busio

# Usado pela aplicação (montado automaticamente pelo compose a partir das vars acima)
# DATABASE_URL=mysql+pymysql://busio:busio@db:3306/busio

# Popula o banco com dados de exemplo na primeira subida
SEED_ON_START=true
